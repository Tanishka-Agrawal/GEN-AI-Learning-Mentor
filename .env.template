# GenAI Learning Mentor - Environment Variables
# Copy this file to '.env' and fill in your details.

# Google Gemini API Key (Required for AI features, embeddings, and tutoring)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Flask Secret Key for session signing (Required for login/auth)
FLASK_SECRET_KEY=YOUR_FLASK_SECRET_KEY_HERE

# --- OTP / Registration Configuration ---
# The OTP system works in two modes:
# 1. DEV MODE (default): When SMTP/SMS credentials are not configured, OTP is printed to console
# 2. PRODUCTION MODE: When credentials are configured, real OTP is sent via email/SMS

# To force production mode even without credentials, set OTP_DEV_MODE=false
# To force dev mode even with credentials, set OTP_DEV_MODE=true
OTP_DEV_MODE=true

# Email OTP Configuration (Gmail example)
# To use Gmail: Generate an App Password at https://myaccount.google.com/apppasswords
# Do NOT use your regular Gmail password - it will not work!
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SMS OTP Configuration - Twilio (recommended for international)
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# SMS OTP Configuration - Fast2SMS (India only)
# Get API key from: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key

